# export LITELLM_MASTER_KEY=<key>
export LITELLM_URL="http://127.0.0.1:4000/v1/chat/completions"
export LITELLM_MODEL="gemini-flash"
export LITELLM_ENABLE_SEARCH="true"

# SSH / OCI Remote VM Configurations
export OCI_IP="<vm_ip>"
export OCI_USER="ubuntu"
export SSH_KEY="~/.ssh/id_ecdsa"

# Check if SSH tunnel is already running before starting it
if ! pgrep -f "L 4000:127.0.0.1:4000" > /dev/null; then
    echo "Starting securely encrypted LiteLLM tunnel..."
    ssh -i $SSH_KEY -f -N -L 4000:127.0.0.1:4000 $OCI_USER@$OCI_IP
fi